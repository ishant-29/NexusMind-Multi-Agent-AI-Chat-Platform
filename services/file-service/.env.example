NODE_ENV=development
PORT=4003

# Database
MONGODB_URI=mongodb://localhost:27017/nexusmind

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Services
AUTH_SERVICE_URL=http://localhost:4000

# CORS
CORS_ORIGIN=http://localhost:3000

# Shared secret for internal service-to-service calls (file service document APIs)
SERVICE_API_KEY=dev-service-key

# Embeddings: set one of these. OPENAI_API_KEY uses OpenAI (text-embedding-3-small);
# otherwise OPENROUTER_API_KEY uses OpenRouter (default: free NVIDIA Nemotron model)
OPENROUTER_API_KEY=sk-or-v1-...
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
